{
  "name": "Noir",
  "version": "1.0.0",
  "author": "TinyCMS",
  "description": "Dark editorial TinyCMS theme with a right sidebar.",
  "features": [
    "responsive",
    "widgets",
    "menu",
    "search",
    "logo",
    "favicon",
    "custom_css",
    "layout_width",
    "colors"
  ],
  "customizer": {
    "sections": [
      {
        "key": "branding",
        "label": "Branding",
        "fields": ["brand_display", "logo", "favicon"]
      },
      {
        "key": "layout",
        "label": "Layout and features",
        "fields": ["layout_width", "enable_search", "enable_widgets", "footer_text"]
      },
      {
        "key": "colors",
        "label": "Colors",
        "fields": ["color_bg", "color_surface", "color_surface_alt", "color_text", "color_muted", "color_border", "color_accent", "color_accent_strong", "color_accent_soft"]
      },
      {
        "key": "advanced",
        "label": "Custom CSS",
        "fields": ["custom_css"]
      }
    ]
  },
  "settings": {
    "brand_display": {
      "type": "select",
      "label": "Branding",
      "default": "both",
      "options": {
        "both": "Logo and title",
        "logo": "Logo only",
        "title": "Title only",
        "none": "No branding"
      }
    },
    "logo": {
      "type": "file",
      "label": "Logo",
      "default": ""
    },
    "favicon": {
      "type": "file",
      "label": "Favicon",
      "default": ""
    },
    "enable_widgets": {
      "type": "checkbox",
      "label": "Enable right sidebar",
      "default": "1"
    },
    "enable_search": {
      "type": "checkbox",
      "label": "Enable search bar",
      "default": "1"
    },
    "layout_width": {
      "type": "select",
      "label": "Layout width",
      "default": "default",
      "options": {
        "narrow": "Narrow",
        "default": "Default",
        "wide": "Wide",
        "full": "Full"
      }
    },
    "custom_css": {
      "type": "textarea",
      "label": "Custom CSS",
      "default": "",
      "max": 20000
    },
    "color_bg": {
      "type": "color",
      "label": "Page background",
      "default": "#090b10"
    },
    "color_surface": {
      "type": "color",
      "label": "Surface",
      "default": "#11151d"
    },
    "color_surface_alt": {
      "type": "color",
      "label": "Muted surface",
      "default": "#1a2130"
    },
    "color_text": {
      "type": "color",
      "label": "Text",
      "default": "#f4f1e8"
    },
    "color_muted": {
      "type": "color",
      "label": "Muted text",
      "default": "#9ba3b4"
    },
    "color_border": {
      "type": "color",
      "label": "Border",
      "default": "#303848"
    },
    "color_accent": {
      "type": "color",
      "label": "Accent",
      "default": "#d8aa5b"
    },
    "color_accent_strong": {
      "type": "color",
      "label": "Accent strong",
      "default": "#f0c778"
    },
    "color_accent_soft": {
      "type": "color",
      "label": "Accent soft",
      "default": "#292112"
    },
    "footer_text": {
      "type": "textarea",
      "label": "Footer text",
      "default": ""
    }
  }
}
